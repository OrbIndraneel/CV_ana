# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=resume_analyzer
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/resume_analyzer

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# JWT Authentication
# Generate a secure random key in production using: openssl rand -hex 32
SECRET_KEY=supersecretkeychangeinproduction
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Settings
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
ALLOWED_HOSTS=["*"]

# NLP Models Storage Path (optional, defaults to standard cache)
HF_HOME=/app/app/nlp/models/huggingface
SPACY_MODEL_PATH=/app/app/nlp/models/spacy
